        "title": "TREGUA,LE TRE CONDIZIONI DI MOSCA A USA Già state rese note dal Cremlino",
        "date_raw": "March 13, 2025",
        "date": "2025-03-13",
        "url": "http://www.servizitelevideo.rai.it/televideo/pub/solotesto.jsp?categoria=Dal%20Mondo&pagina=150",
